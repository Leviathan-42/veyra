@@ -0,0 +1,72 @@
+package net.vulkanmod.config.shader;
+
+import net.minecraft.client.Minecraft;
+
+import java.io.File;
+import java.util.ArrayList;
+import java.util.Comparator;
+import java.util.List;
+import java.util.Locale;
+
+/**
+ * Discovers shaderpacks for the experimental Vulkan shader menu.
+ *
+ * This deliberately only indexes packs for now. Loading a pack requires a Vulkan
+ * render graph/compatibility layer for Iris-style passes and uniforms.
+ */
+public final class ShaderPackManager {
+    public static final String OFF = "OFF";
+
+    private ShaderPackManager() {
+    }
+
+    public static String[] getAvailableShaderPacks() {
+        List<String> packs = new ArrayList<>();
+        packs.add(OFF);
+
+        File gameDirectory = Minecraft.getInstance().gameDirectory;
+        scanDirectory(new File(gameDirectory, "shaderpacks"), packs);
+        scanDirectory(new File(gameDirectory, "vulkan-shaderpacks"), packs);
+
+        return packs.stream()
+                .distinct()
+                .sorted(Comparator.comparing(value -> value.equals(OFF) ? "" : value.toLowerCase(Locale.ROOT)))
+                .toArray(String[]::new);
+    }
+
+    public static String normalizeSelection(String selection) {
+        if (selection == null || selection.isBlank()) {
+            return OFF;
+        }
+
+        for (String pack : getAvailableShaderPacks()) {
+            if (pack.equals(selection)) {
+                return selection;
+            }
+        }
+
+        return OFF;
+    }
+
+    public static boolean isShaderEnabled(String selection) {
+        return selection != null && !selection.equals(OFF);
+    }
+
+    private static void scanDirectory(File directory, List<String> packs) {
+        File[] files = directory.listFiles();
+        if (files == null) {
+            return;
+        }
+
+        for (File file : files) {
+            if (file.isDirectory()) {
+                if (new File(file, "shaders").isDirectory()) {
+                    packs.add(file.getName());
+                }
+            }
+            else if (file.isFile() && file.getName().toLowerCase(Locale.ROOT).endsWith(".zip")) {
+                packs.add(file.getName());
+            }
+        }
+    }
+}
