{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veyra Launcher",
  "version": "0.1.0",
  "identifier": "dev.blocktracker.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Veyra Launcher",
        "width": 1060,
        "height": 680,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": []
  },
  "plugins": {
    "opener": {}
  }
}
