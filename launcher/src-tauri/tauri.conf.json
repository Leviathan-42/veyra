{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Veyra Launcher",
  "version": "0.1.0",
  "identifier": "dev.blocktracker.launcher",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Veyra Launcher",
        "width": 1060,
        "height": 680,
        "minWidth": 860,
        "minHeight": 560,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "publisher": "Veyra",
    "category": "Game",
    "shortDescription": "Veyra Minecraft launcher and client utility suite",
    "longDescription": "Installs and launches a managed Minecraft Java Edition instance with Fabric, Veyra, renderer profiles, performance mods, and automatic Java provisioning.",
    "copyright": "Copyright 2026 Veyra",
    "resources": {
      "../../mod/build/libs/block-tracker-0.1.0.jar": "resources/block-tracker-0.1.0.jar"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "embedBootstrapper",
        "silent": true
      },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "uninstallerIcon": "icons/icon.ico"
      }
    }
  },
  "plugins": {
    "opener": {}
  }
}
